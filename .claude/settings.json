{
  "env": {
    "DISABLE_PROMPT_CACHING": "false",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "true",
    "CLAUDE_CODE_DISABLE_BACKGROUND_TASKS": "true"
  },
  "effortLevel": "medium",
  "BASH_MAX_OUTPUT_LENGTH": "200000",
  "permissions": {
    "deny": [
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(*.lock)",
      "Read(.expo/**)",
      "Read(android/**)",
      "Read(ios/**)"
    ]
  }
}
